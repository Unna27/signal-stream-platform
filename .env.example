# Kafka Configuration
# The Kafka broker address(es) to connect to
KAFKA_BROKER=localhost:9092

# Signal Processor Topics
# Topic to consume raw signals from
SIGNAL_INPUT_TOPIC=raw-signals
# Topic to publish processed signals to
SIGNAL_OUTPUT_TOPIC=processed-signals
# Topic to publish failed storage signals to
SIGNAL_FAILED_TOPIC=storage-signals-failed

# Database Configuration
# PostgreSQL connection string for data persistence
DATABASE_URL=postgresql://user:password@localhost:5432/signal_db
